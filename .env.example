# ตัวอย่าง environment variables สำหรับ Zeelink
# คัดลอกไฟล์นี้เป็น .env แล้วแทนค่าด้วยของคุณ
#
# วิธีสร้างค่าเหล่านี้: สร้างโปรเจกต์ที่ https://supabase.com (ฟรี)
# แล้วดูที่ Project Settings → API จะเห็น Project URL และ anon public key

# Supabase (หน้าบัญชีเว็บ + ฐานข้อมูล)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Gemini API (สำหรับ Server/ai.js — ฝั่ง server เท่านั้น ห้ามขึ้นต้น VITE_)
# คีย์นี้ปลอดภัยเพราะไม่ถูก bundle ลง client (ดูที่ https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key

# AI Mascot (Groq) — ฝั่ง server เท่านั้น (ใช้โดย api/ai.js)
# ⚠️ สำคัญ: ห้ามตั้งชื่อตัวแปรขึ้นต้นด้วย VITE_ เด็ดขาด มิฉะนั้นคีย์จะรั่วลง browser ทันที
#    ถ้าเคยตั้งเป็น VITE_AI_API_KEY มาก่อน ให้ถือว่าคีย์นั้น "รั่วแล้ว" และต้องไปหมุนคีย์ใหม่ทันที
#    ดูคำแนะนำใน SECURITY_FIXES.md
AI_API_KEY=your-groq-api-key
AI_API_URL=https://api.groq.com/openai/v1/chat/completions
